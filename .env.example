# Copy this to .env.local and fill in real tokens. .env.local is gitignored.

# Mastodon: https://fosstodon.org/@osarch
# Needs write:statuses and write:media permissions, or the broader write permission.
MASTODON_ACCESS_TOKEN=replace-me

# X / Twitter:
# Needs a user access token with tweet.write scope.
X_ACCESS_TOKEN=replace-me
